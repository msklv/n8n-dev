# ── n8n ───────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
GENERIC_TIMEZONE=Europe/Kaliningrad

# Encryption key — keep stable between restarts
# Generate your own:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=d5891a5ce5bb006c589e5cdbe02890ac25c744ecef9f6debe84f01410297a8d3
